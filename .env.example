POSTGRES_DB=servicedesk
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API (compose)
ASPNETCORE_ENVIRONMENT=Development
CONNECTIONSTRINGS__DEFAULT=Host=db;Port=5432;Database=servicedesk;Username=postgres;Password=postgres

# JWT (пример)
JWT__ISSUER=ServiceDesk
JWT__AUDIENCE=ServiceDesk.Client
JWT__KEY=CHANGE_ME_TO_A_LONG_RANDOM_SECRET
JWT__EXPIRES_MINUTES=60

# optional seed admin (пример)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=Admin123!
